{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "enable": true,
        "hide": false,
        "iconColor": "orange",
        "name": "Anomalies",
        "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"anomaly_severity\" and r._value != \"\") |> map(fn: (r) => ({ r with _value: r._value }))"
      }
    ]
  },
  "description": "PC Power Monitoring Dashboard — CODEC",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Global",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 400 }
            ]
          },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Wall Power",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"wall_watts\" and r.host == \"CODEC\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.07 }, { "color": "red", "value": 0.10 }] },
          "unit": "currencyEUR",
          "decimals": 4
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Cost / Hour",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cost_per_hour\" and r.host == \"CODEC\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyEUR",
          "decimals": 3
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto" },
      "title": "Cost Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: today()) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cost_per_hour\" and r.host == \"CODEC\") |> aggregateWindow(every: 1h, fn: mean) |> sum()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyEUR",
          "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto" },
      "title": "Cost This Month",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: -30d) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cost_per_hour\" and r.host == \"CODEC\") |> aggregateWindow(every: 1h, fn: mean) |> sum()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "": { "color": "green", "index": 0, "text": "OK" } }, "type": "value" },
            { "options": { "INFO": { "color": "blue", "index": 1, "text": "INFO" }, "WARNING": { "color": "orange", "index": 2, "text": "WARNING" }, "CRITICAL": { "color": "red", "index": 3, "text": "CRITICAL" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "System Status",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: -1m) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"anomaly_severity\" and r.host == \"CODEC\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "watt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 145 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "title": "CPU Power Draw",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cpu_power_w\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 85 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "CPU Temperature",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cpu_temp_c\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2 },
          "unit": "megahz"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "CPU Effective Clock",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"cpu_clock_mhz\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "GPU (AMD RX 9070 XT — puissance estimée)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "watt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 242 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "GPU Power Draw (estimé ⚠️)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"gpu_power_w\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "dark-red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "GPU Temperature",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"gpu_temp_c\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": { "lineWidth": 2 },
          "unit": "megahz"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "GPU Clock",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"gpu_clock_mhz\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Rails électriques (ATX)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "volt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "12V" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }, { "id": "custom.thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 11.4 }, { "color": "red", "value": 12.6 }] } }] },
          { "matcher": { "id": "byName", "options": "5V" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "3.3V" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "calcs": ["mean", "min", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Voltage Rails (12V / 5V / 3.3V)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and (r._field == \"rail_12v\" or r._field == \"rail_5v\" or r._field == \"rail_3v3\") and r.host == \"CODEC\") |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\") |> rename(columns: {rail_12v: \"12V\", rail_5v: \"5V\", rail_3v3: \"3.3V\"})",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "custom": { "lineWidth": 2 },
          "unit": "volt",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.05 }, { "color": "red", "value": 0.1 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "12V Rail Std Dev (instabilité — seuil 0.1V)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"rail_12v\" and r.host == \"CODEC\") |> timedMovingAverage(every: 2s, period: 10s) |> stddev()",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Stockage (NVMe)",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "super-light-blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 55 }, { "color": "red", "value": 70 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 40,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "NVMe Temperature",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"nvme_temp_c\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "light-blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 41,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "NVMe Power (0 = estimation forfaitaire 6W)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"hardware\" and r._field == \"nvme_power_w\" and r.host == \"CODEC\")",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "title": "Énergie & Coût",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "gradientMode": "none" },
          "unit": "kwatth"
        }
      },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 42 },
      "id": 50,
      "options": {
        "barWidth": 0.9,
        "groupWidth": 0.7,
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "stacking": "normal",
        "tooltip": { "mode": "single" },
        "xField": "_time"
      },
      "title": "kWh par heure (24h) — CPU / GPU / Reste",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"pc-monitor\") |> range(start: -24h) |> filter(fn: (r) => r._measurement == \"hardware\" and (r._field == \"cpu_power_w\" or r._field == \"gpu_power_w\" or r._field == \"wall_watts\") and r.host == \"CODEC\") |> aggregateWindow(every: 1h, fn: mean) |> map(fn: (r) => ({ r with _value: r._value / 1000.0 }))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 1 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cpu_power_w" }, "properties": [{ "id": "displayName", "value": "CPU" }] },
          { "matcher": { "id": "byName", "options": "gpu_power_w" }, "properties": [{ "id": "displayName", "value": "GPU" }] },
          { "matcher": { "id": "byName", "options": "ram_power_w" }, "properties": [{ "id": "displayName", "value": "RAM (est.)" }] },
          { "matcher": { "id": "byName", "options": "mobo_power_w" }, "properties": [{ "id": "displayName", "value": "Mobo (est.)" }] },
          { "matcher": { "id": "byName", "options": "nvme_power_w" }, "properties": [{ "id": "displayName", "value": "NVMe" }] }
        ]
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 42 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "pieType": "pie", "tooltip": { "mode": "single" } },
      "title": "Breakdown conso par composant (%)",
      "type": "piechart",
